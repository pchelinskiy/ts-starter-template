{
  "name": "ts-starter-template",
  "version": "1.0.0",
  "description": "TypeScript starter template with modern tooling",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "prepare": "husky || true",
    "build": "swc src -d dist --source-maps --delete-dir-on-start",
    "build:prod": "pnpm run clean && pnpm run typecheck && pnpm run build",
    "build:watch": "swc src -d dist --source-maps --watch",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "start:prod": "NODE_ENV=production node dist/index.js",
    "clean": "node --run _clean",
    "_clean": "node -e \"const {rmSync}=require('fs');['dist','coverage'].forEach(d=>rmSync(d,{recursive:true,force:true}))\"",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,md}\"",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --cache",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix --cache",
    "lint:ci": "eslint \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:ci": "vitest run --coverage --reporter=verbose",
    "test:e2e": "vitest run --project e2e",
    "ci": "pnpm run typecheck && pnpm run lint:ci && pnpm run test:ci",
    "precommit": "pnpm run lint && pnpm run format",
    "prepush": "pnpm run ci"
  },
  "keywords": [
    "typescript",
    "nodejs",
    "starter",
    "template",
    "swc",
    "vitest",
    "eslint",
    "prettier"
  ],
  "author": "",
  "license": "UNLICENSED",
  "packageManager": "pnpm@11.5.0",
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.39.4",
    "@swc/cli": "^0.7.10",
    "@swc/core": "^1.15.33",
    "@types/node": "^22.19.19",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^3.2.4"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "package.json"
  ]
}
